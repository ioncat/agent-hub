# agent-hub — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=1234567890:AAF...
TELEGRAM_CHAT_ID=123456789           # your Telegram user ID (send /start to @userinfobot)

# ── Optional (defaults shown) ─────────────────────────────────────────────────
LLM_MODEL=claude-opus-4-5
PROFILE_MD_PATH=../callback-cv/skill/PROFILE.md
DB_PATH=db/agent.db
KMP_BASE_URL=http://localhost:8001   # use http://kmp-service:8001 in Docker Compose
MAX_TOKENS=4096
